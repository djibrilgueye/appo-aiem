generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Authentication Models
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  password      String?
  image         String?
  role          String    @default("user") // admin, editor, user
  accounts      Account[]
  sessions      Session[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// IHMA Data Models
model Country {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  region      String
  lat         Float
  lon         Float
  appoMember  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  basins        Basin[]
  reserves      Reserve[]
  productions   Production[]
  refineries    Refinery[]
  trainings     Training[]
  rndCenters    RnDCenter[]
  storages      Storage[]
  petrochemicals Petrochemical[]
  tradeImports  TradeImport[]
  tradeExports  TradeExport[]
}

model Basin {
  id        String   @id @default(cuid())
  basinId   String   @unique
  name      String
  countryId String
  country   Country  @relation(fields: [countryId], references: [id], onDelete: Cascade)
  type      String   // Oil, Gas, Oil & Gas
  lat       Float
  lon       Float
  areaKm2   Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Reserve {
  id        String   @id @default(cuid())
  countryId String
  country   Country  @relation(fields: [countryId], references: [id], onDelete: Cascade)
  year      Int
  oil       Float    // Gbbl
  gas       Float    // Tcf
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([countryId, year])
}

model Production {
  id        String   @id @default(cuid())
  countryId String
  country   Country  @relation(fields: [countryId], references: [id], onDelete: Cascade)
  year      Int
  oil       Float    // kb/d
  gas       Float    // million m³/yr
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([countryId, year])
}

model Pipeline {
  id         String   @id @default(cuid())
  pipelineId String   @unique
  name       String
  countries  String   // JSON array of country codes
  coords     String   // JSON array of coordinates
  status     String   // operational, under construction, proposed
  lengthKm   Int?
  capacity   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Refinery {
  id          String   @id @default(cuid())
  refineryId  String   @unique
  name        String
  countryId   String
  country     Country  @relation(fields: [countryId], references: [id], onDelete: Cascade)
  lat         Float
  lon         Float
  capacityKbd Int
  status      String   // operational, under construction, proposed, idle
  year        Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Training {
  id        String   @id @default(cuid())
  centerId  String   @unique
  name      String
  countryId String
  country   Country  @relation(fields: [countryId], references: [id], onDelete: Cascade)
  lat       Float
  lon       Float
  type      String   // Technical, Academic, Corporate, Research/Training
  year      Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RnDCenter {
  id        String   @id @default(cuid())
  centerId  String   @unique
  name      String
  countryId String
  country   Country  @relation(fields: [countryId], references: [id], onDelete: Cascade)
  lat       Float
  lon       Float
  focus     String
  year      Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Storage {
  id         String   @id @default(cuid())
  storageId  String   @unique
  name       String
  countryId  String
  country    Country  @relation(fields: [countryId], references: [id], onDelete: Cascade)
  lat        Float
  lon        Float
  type       String   // Crude Oil, LNG, Products
  capacityMb Float
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Petrochemical {
  id        String   @id @default(cuid())
  plantId   String   @unique
  name      String
  countryId String
  country   Country  @relation(fields: [countryId], references: [id], onDelete: Cascade)
  lat       Float
  lon       Float
  products  String   // JSON array
  capacity  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TradeImport {
  id          String   @id @default(cuid())
  countryId   String
  country     Country  @relation(fields: [countryId], references: [id], onDelete: Cascade)
  year        Int
  oilKbD      Float
  gasBcm      Float
  mainSources String   // JSON array
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([countryId, year])
}

model TradeExport {
  id               String   @id @default(cuid())
  countryId        String
  country          Country  @relation(fields: [countryId], references: [id], onDelete: Cascade)
  year             Int
  oilKbD           Float
  gasBcm           Float
  mainDestinations String   // JSON array
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([countryId, year])
}
